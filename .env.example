# MailerSend (preferred email provider)
MAILERSEND_API_KEY=mlsn.your_api_key_here
CONTACT_EMAIL_FROM="360ace.NET <no-reply@360ace.net>"

# Cloudflare Turnstile (captcha for contact form)
TURNSTILE_SECRET_KEY=0x4AAAAAAA...your_secret_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...your_site_key
# Require Turnstile in non-production (set to 1). In production, enforcement is automatic when keys are set.
# TURNSTILE_REQUIRE=1

# Rate limiting for contact form
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000

# Preloader TTL override (ms)
NEXT_PUBLIC_PRELOAD_TTL_MS=30000000

# Public site URLs (used for canonical, sitemap, and footer links)
NEXT_PUBLIC_SITE_URL=https://360ace.net
NEXT_PUBLIC_TECH_URL=https://360ace.tech
NEXT_PUBLIC_FOOD_URL=https://360ace.food

# Socials
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/360ace/

# Comma-separated allowlist for Origin/Referer (security)
CONTACT_ALLOWED_ORIGINS=https://360ace.net,https://www.360ace.net,http://localhost
# Expected X-Requested-With header value from the client
CONTACT_REQUESTED_WITH=XMLHttpRequest

# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code

# Optional: disable Next.js telemetry locally
# NEXT_TELEMETRY_DISABLED=1

# Docker build flag (automatically set during Docker builds)
# DOCKER_BUILD=true
